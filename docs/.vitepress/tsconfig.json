{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true,
    "paths": {
      "~/models/*": ["../models/*"],
      "~/recording/*": ["../recording/*"],
      "~/docs/*": ["../*"],
      "~/svg/*": ["../svg/*"],
    }
  },
  "include": [
    "**/*.ts",
    "**/*.vue"
  ]
}
